# =============================================================
#  [.tikzon] — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# =============================================================

# -------------------------------------------------------------
# EMAIL — Gmail SMTP
# Use an App Password, not your regular Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on your account)
# -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password
OPERATOR_EMAIL=where_digest_is_sent@gmail.com

# -------------------------------------------------------------
# GOOGLE SHEETS
# See README.md → "Google Sheets Setup" for full instructions.
# -------------------------------------------------------------
GOOGLE_SHEETS_CREDENTIALS_JSON=config/service_account.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# -------------------------------------------------------------
# TIKTOK DATA SOURCES (optional but recommended)
# Without these, the agent falls back to direct TikTok scraping.
# FastMoss: https://www.fastmoss.com  (free tier available)
# Kalodata: https://www.kalodata.com  (paid, better data)
# To get your session cookie: log in → open DevTools (F12)
# → Application → Cookies → copy the value of the session cookie
# -------------------------------------------------------------
FASTMOSS_SESSION_COOKIE=
KALODATA_SESSION_COOKIE=

# -------------------------------------------------------------
# SCHEDULING
# Timezone list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# SCAN_HOUR uses 24-hour format. Default: 5:00 AM operator local time.
# -------------------------------------------------------------
OPERATOR_TIMEZONE=America/New_York
SCAN_HOUR=5
SCAN_MINUTE=0

# -------------------------------------------------------------
# SCAN PARAMETERS (optional — override scan_config.json values)
# Uncomment to override defaults.
# -------------------------------------------------------------
# MARGIN_THRESHOLD=0.30
# MAX_TEST_BUDGET=100
# COMPETITION_CEILING=10
